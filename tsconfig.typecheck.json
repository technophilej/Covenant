{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "next.config.js",
    "tailwind.config.js",
    "postcss.config.js",
    "eslint.config.mjs",
    "tests/**/*.mjs"
  ]
}
